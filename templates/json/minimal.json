{
  "name": "Minimal",
  "description": "A clean, minimal template with hero section and content",
  "category": "general",
  "thumbnail_url": "",
  "html_content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>{% if title and title != site_name %}{{ title }} - {% endif %}{{ site_name }}</title>\n    {% if site_description %}<meta name=\"description\" content=\"{{ site_description }}\">{% endif %}\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\n    <style>\n        :root {\n            --bg-color: var(--bg-color-light, #ffffff);\n            --text-color: var(--text-color-light, #333333);\n            --accent-color: {{ accent_color | default('#0066cc') }};\n            --nav-bg: var(--nav-bg-light, #ffffff);\n            --nav-text: var(--nav-text-light, #333333);\n            --card-bg: var(--card-bg-light, #f6f8fa);\n            --border-color: var(--border-color-light, #e1e4e8);\n        }\n        [data-theme=\"dark\"] {\n            --bg-color: #0d1117;\n            --text-color: #c9d1d9;\n            --nav-bg: #161b22;\n            --nav-text: #c9d1d9;\n            --card-bg: #161b22;\n            --border-color: #30363d;\n        }\n        * { margin: 0; padding: 0; box-sizing: border-box; }\n        body {\n            font-family: {{ font_body | default('system-ui, -apple-system, sans-serif') }};\n            background: var(--bg-color);\n            color: var(--text-color);\n            line-height: 1.6;\n        }\n        a { color: var(--accent-color); text-decoration: none; }\n        a:hover { text-decoration: underline; }\n        \n        header {\n            background: var(--nav-bg);\n            border-bottom: 1px solid var(--border-color);\n            padding: 1rem 2rem;\n            position: sticky;\n            top: 0;\n            z-index: 100;\n        }\n        .header-content {\n            max-width: 1200px;\n            margin: 0 auto;\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n        }\n        .logo {\n            font-size: 1.5rem;\n            font-weight: bold;\n            color: var(--accent-color);\n        }\n        nav ul {\n            display: flex;\n            list-style: none;\n            gap: 1.5rem;\n        }\n        nav a {\n            color: var(--nav-text);\n            font-weight: 500;\n        }\n        \n        .hero {\n            background: linear-gradient(135deg, var(--accent-color), #004499);\n            color: white;\n            padding: 4rem 2rem;\n            text-align: center;\n        }\n        .hero h1 {\n            font-size: 3rem;\n            margin-bottom: 1rem;\n            font-family: {{ font_heading | default('system-ui') }};\n        }\n        .hero p {\n            font-size: 1.25rem;\n            opacity: 0.9;\n            max-width: 600px;\n            margin: 0 auto 2rem;\n        }\n        .hero .cta {\n            display: inline-block;\n            background: white;\n            color: var(--accent-color);\n            padding: 0.75rem 2rem;\n            border-radius: 8px;\n            font-weight: 600;\n            margin: 0.5rem;\n        }\n        \n        main {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 3rem 2rem;\n        }\n        \n        article {\n            background: var(--card-bg);\n            border: 1px solid var(--border-color);\n            border-radius: 12px;\n            padding: 2rem;\n            margin-bottom: 2rem;\n        }\n        article h2 {\n            font-family: {{ font_heading | default('system-ui') }};\n            margin-bottom: 1rem;\n        }\n        .meta {\n            color: var(--text-color);\n            opacity: 0.7;\n            font-size: 0.9rem;\n            margin-bottom: 1rem;\n        }\n        \n        footer {\n            background: var(--nav-bg);\n            border-top: 1px solid var(--border-color);\n            padding: 2rem;\n            text-align: center;\n            margin-top: 4rem;\n        }\n        footer p {\n            opacity: 0.7;\n        }\n    </style>\n</head>\n<body>\n    <header>\n        <div class=\"header-content\">\n            <a href=\"/\" class=\"logo\">{{ site_name }}</a>\n            <nav>\n                <ul>\n                    {% for link in nav_links %}\n                    <li><a href=\"{{ link.url }}\">{{ link.label }}</a></li>\n                    {% endfor %}\n                </ul>\n            </nav>\n        </div>\n    </header>\n    \n    <section class=\"hero\">\n        <h1>{{ hero_title | default('Welcome') }}</h1>\n        <p>{{ hero_subtitle | default('A minimal, clean blog template') }}</p>\n        {% if hero_cta_text %}\n        <a href=\"{{ hero_cta_link | default('/') }}\" class=\"cta\">{{ hero_cta_text }}</a>\n        {% endif %}\n    </section>\n    \n    <main>\n        {{ content | safe }}\n    </main>\n    \n    <footer>\n        <p>&copy; 2026 {{ site_name }}. All rights reserved.</p>\n    </footer>\n</body>\n</html>",
  "css_content": "",
  "js_content": "",
  "default_config": {
    "accent_color": "#0066cc",
    "font_heading": "system-ui",
    "font_body": "system-ui, -apple-system, sans-serif",
    "hero_title": "Welcome",
    "hero_subtitle": "A minimal, clean blog template",
    "hero_cta_text": "",
    "hero_cta_link": "/"
  }
}

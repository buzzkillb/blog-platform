{
  "name": "Portfolio",
  "description": "Visual-focused template with hero image and project grid",
  "category": "portfolio",
  "thumbnail_url": "",
  "html_content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>{% if title and title != site_name %}{{ title }} - {% endif %}{{ site_name }}</title>\n    {% if site_description %}<meta name=\"description\" content=\"{{ site_description }}\">{% endif %}\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\n    <style>\n        :root {\n            --bg-color: var(--bg-color-light, #fafafa);\n            --text-color: var(--text-color-light, #1a1a1a);\n            --accent-color: {{ accent_color | default('#e11d48') }};\n            --nav-bg: transparent;\n            --nav-text: var(--text-color-light, #1a1a1a);\n            --card-bg: var(--card-bg-light, #ffffff);\n            --border-color: var(--border-color-light, #e5e5e5);\n        }\n        [data-theme=\"dark\"] {\n            --bg-color: #0a0a0a;\n            --text-color: #fafafa;\n            --nav-bg: transparent;\n            --nav-text: #fafafa;\n            --card-bg: #171717;\n            --border-color: #262626;\n        }\n        * { margin: 0; padding: 0; box-sizing: border-box; }\n        body {\n            font-family: {{ font_body | default('system-ui, -apple-system, sans-serif') }};\n            background: var(--bg-color);\n            color: var(--text-color);\n            line-height: 1.6;\n        }\n        a { color: var(--accent-color); text-decoration: none; }\n        a:hover { text-decoration: underline; }\n        \n        header {\n            position: fixed;\n            top: 0;\n            left: 0;\n            right: 0;\n            padding: 1.5rem 3rem;\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            z-index: 100;\n            background: linear-gradient(to bottom, rgba(0,0,0,0.5), transparent);\n        }\n        [data-theme=\"dark\"] header {\n            background: linear-gradient(to bottom, rgba(0,0,0,0.8), transparent);\n        }\n        .logo {\n            font-size: 1.5rem;\n            font-weight: bold;\n            color: var(--nav-text);\n        }\n        nav ul {\n            display: flex;\n            list-style: none;\n            gap: 2rem;\n        }\n        nav a {\n            color: var(--nav-text);\n            font-weight: 500;\n        }\n        \n        .hero {\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            text-align: center;\n            padding: 2rem;\n            background: linear-gradient(135deg, #1a1a1a 0%, #4a1a2e 100%);\n            color: white;\n            position: relative;\n        }\n        [data-theme=\"light\"] .hero {\n            background: linear-gradient(135deg, #fafafa 0%, #e5e5e5 100%);\n            color: var(--text-color-light, #1a1a1a);\n        }\n        .hero-content {\n            max-width: 800px;\n        }\n        .hero h1 {\n            font-family: {{ font_heading | default('system-ui') }};\n            font-size: 4rem;\n            font-weight: 800;\n            margin-bottom: 1.5rem;\n            letter-spacing: -0.02em;\n        }\n        .hero p {\n            font-size: 1.5rem;\n            opacity: 0.9;\n            margin-bottom: 2rem;\n        }\n        .hero .cta {\n            display: inline-block;\n            background: var(--accent-color);\n            color: white;\n            padding: 1rem 2.5rem;\n            border-radius: 50px;\n            font-weight: 600;\n            font-size: 1.1rem;\n            transition: transform 0.2s, box-shadow 0.2s;\n        }\n        .hero .cta:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 8px 24px rgba(225, 29, 72, 0.4);\n            text-decoration: none;\n        }\n        \n        section {\n            padding: 6rem 2rem;\n            max-width: 1400px;\n            margin: 0 auto;\n        }\n        .section-title {\n            font-family: {{ font_heading | default('system-ui') }};\n            font-size: 2.5rem;\n            text-align: center;\n            margin-bottom: 3rem;\n        }\n        \n        .projects-grid {\n            display: grid;\n            grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));\n            gap: 2rem;\n        }\n        @media (max-width: 500px) {\n            .projects-grid { grid-template-columns: 1fr; }\n        }\n        .project-card {\n            background: var(--card-bg);\n            border: 1px solid var(--border-color);\n            border-radius: 16px;\n            overflow: hidden;\n            transition: transform 0.3s, box-shadow 0.3s;\n        }\n        .project-card:hover {\n            transform: translateY(-8px);\n            box-shadow: 0 20px 40px rgba(0,0,0,0.15);\n        }\n        .project-card img {\n            width: 100%;\n            height: 250px;\n            object-fit: cover;\n        }\n        .project-content {\n            padding: 2rem;\n        }\n        .project-card h3 {\n            font-family: {{ font_heading | default('system-ui') }};\n            font-size: 1.5rem;\n            margin-bottom: 0.5rem;\n        }\n        .project-card .category {\n            color: var(--accent-color);\n            font-size: 0.875rem;\n            font-weight: 600;\n            text-transform: uppercase;\n            letter-spacing: 0.05em;\n            margin-bottom: 1rem;\n        }\n        .project-card .description {\n            opacity: 0.8;\n            margin-bottom: 1.5rem;\n        }\n        .project-card .link {\n            font-weight: 600;\n        }\n        \n        .about-section {\n            display: grid;\n            grid-template-columns: 1fr 1fr;\n            gap: 4rem;\n            align-items: center;\n        }\n        @media (max-width: 768px) {\n            .about-section { grid-template-columns: 1fr; }\n        }\n        .about-image {\n            width: 100%;\n            height: 500px;\n            object-fit: cover;\n            border-radius: 16px;\n        }\n        .about-content h2 {\n            font-family: {{ font_heading | default('system-ui') }};\n            font-size: 2.5rem;\n            margin-bottom: 1.5rem;\n        }\n        .about-content p {\n            font-size: 1.1rem;\n            opacity: 0.8;\n            margin-bottom: 2rem;\n        }\n        .social-links {\n            display: flex;\n            gap: 1rem;\n        }\n        .social-links a {\n            width: 48px;\n            height: 48px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            border-radius: 50%;\n            background: var(--card-bg);\n            border: 1px solid var(--border-color);\n            font-size: 1.25rem;\n        }\n        \n        footer {\n            background: var(--card-bg);\n            border-top: 1px solid var(--border-color);\n            padding: 4rem 2rem;\n            text-align: center;\n        }\n        footer p {\n            opacity: 0.6;\n        }\n    </style>\n</head>\n<body>\n    <header>\n        <a href=\"/\" class=\"logo\">{{ site_name }}</a>\n        <nav>\n            <ul>\n                {% for link in nav_links %}\n                <li><a href=\"{{ link.url }}\">{{ link.label }}</a></li>\n                {% endfor %}\n            </nav>\n        </header>\n    </header>\n    \n    <section class=\"hero\">\n        <div class=\"hero-content\">\n            <h1>{{ hero_title | default('Creative Developer') }}</h1>\n            <p>{{ hero_subtitle | default('Building beautiful digital experiences') }}</p>\n            {% if hero_cta_text %}\n            <a href=\"{{ hero_cta_link | default('/projects') }}\" class=\"cta\">{{ hero_cta_text }}</a>\n            {% endif %}\n        </div>\n    </section>\n    \n    <section>\n        <h2 class=\"section-title\">Featured Projects</h2>\n        <div class=\"projects-grid\">\n            {{ content | safe }}\n        </div>\n    </section>\n    \n    <section class=\"about-section\">\n        <img src=\"{{ about_image | default('https://picsum.photos/800/1000') }}\" alt=\"About\" class=\"about-image\">\n        <div class=\"about-content\">\n            <h2>About Me</h2>\n            <p>{{ about_text | default('I am a creative developer passionate about building beautiful, functional websites and applications. With expertise in modern web technologies, I transform ideas into digital reality.') }}</p>\n            <div class=\"social-links\">\n                <a href=\"#\"><i class=\"fab fa-github\"></i></a>\n                <a href=\"#\"><i class=\"fab fa-twitter\"></i></a>\n                <a href=\"#\"><i class=\"fab fa-linkedin\"></i></a>\n                <a href=\"#\"><i class=\"fas fa-envelope\"></i></a>\n            </div>\n        </div>\n    </section>\n    \n    <footer>\n        <p>&copy; 2026 {{ site_name }}. All rights reserved.</p>\n    </footer>\n</body>\n</html>",
  "css_content": "",
  "js_content": "",
  "default_config": {
    "accent_color": "#e11d48",
    "font_heading": "system-ui",
    "font_body": "system-ui, -apple-system, sans-serif",
    "hero_title": "Creative Developer",
    "hero_subtitle": "Building beautiful digital experiences",
    "hero_cta_text": "View Projects",
    "hero_cta_link": "/projects",
    "about_image": "https://picsum.photos/800/1000",
    "about_text": "I am a creative developer passionate about building beautiful, functional websites and applications."
  }
}

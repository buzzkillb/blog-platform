{
  "name": "Blog",
  "description": "Classic blog layout with post grid and sidebar",
  "category": "blog",
  "thumbnail_url": "",
  "html_content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>{% if title and title != site_name %}{{ title }} - {% endif %}{{ site_name }}</title>\n    {% if site_description %}<meta name=\"description\" content=\"{{ site_description }}\">{% endif %}\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\n    <style>\n        :root {\n            --bg-color: var(--bg-color-light, #ffffff);\n            --text-color: var(--text-color-light, #333333);\n            --accent-color: {{ accent_color | default('#2ea44f') }};\n            --nav-bg: var(--nav-bg-light, #24292f);\n            --nav-text: #ffffff;\n            --card-bg: var(--card-bg-light, #ffffff);\n            --border-color: var(--border-color-light, #d0d7de);\n            --sidebar-bg: var(--card-bg-light, #f6f8fa);\n        }\n        [data-theme=\"dark\"] {\n            --bg-color: #0d1117;\n            --text-color: #c9d1d9;\n            --nav-bg: #161b22;\n            --card-bg: #161b22;\n            --border-color: #30363d;\n            --sidebar-bg: #161b22;\n        }\n        * { margin: 0; padding: 0; box-sizing: border-box; }\n        body {\n            font-family: {{ font_body | default('system-ui, -apple-system, sans-serif') }};\n            background: var(--bg-color);\n            color: var(--text-color);\n            line-height: 1.6;\n        }\n        a { color: var(--accent-color); text-decoration: none; }\n        a:hover { text-decoration: underline; }\n        \n        header {\n            background: var(--nav-bg);\n            padding: 1rem 2rem;\n        }\n        .header-content {\n            max-width: 1200px;\n            margin: 0 auto;\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n        }\n        .logo {\n            font-size: 1.5rem;\n            font-weight: bold;\n            color: var(--nav-text);\n        }\n        nav ul {\n            display: flex;\n            list-style: none;\n            gap: 1.5rem;\n        }\n        nav a {\n            color: var(--nav-text);\n            font-weight: 500;\n        }\n        \n        .page-header {\n            background: var(--sidebar-bg);\n            border-bottom: 1px solid var(--border-color);\n            padding: 3rem 2rem;\n            text-align: center;\n        }\n        .page-header h1 {\n            font-family: {{ font_heading | default('system-ui') }};\n            font-size: 2.5rem;\n            margin-bottom: 0.5rem;\n        }\n        \n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n            display: grid;\n            grid-template-columns: 1fr 300px;\n            gap: 2rem;\n        }\n        @media (max-width: 768px) {\n            .container { grid-template-columns: 1fr; }\n        }\n        \n        .posts-grid {\n            display: grid;\n            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));\n            gap: 2rem;\n        }\n        .post-card {\n            background: var(--card-bg);\n            border: 1px solid var(--border-color);\n            border-radius: 12px;\n            overflow: hidden;\n            transition: transform 0.2s, box-shadow 0.2s;\n        }\n        .post-card:hover {\n            transform: translateY(-4px);\n            box-shadow: 0 8px 24px rgba(0,0,0,0.15);\n        }\n        .post-card img {\n            width: 100%;\n            height: 200px;\n            object-fit: cover;\n        }\n        .post-content {\n            padding: 1.5rem;\n        }\n        .post-card h3 {\n            font-family: {{ font_heading | default('system-ui') }};\n            margin-bottom: 0.5rem;\n        }\n        .meta {\n            color: var(--text-color);\n            opacity: 0.7;\n            font-size: 0.875rem;\n            margin-bottom: 1rem;\n        }\n        .excerpt {\n            color: var(--text-color);\n            opacity: 0.8;\n        }\n        \n        .sidebar {\n            display: flex;\n            flex-direction: column;\n            gap: 2rem;\n        }\n        .sidebar-widget {\n            background: var(--sidebar-bg);\n            border: 1px solid var(--border-color);\n            border-radius: 12px;\n            padding: 1.5rem;\n        }\n        .sidebar-widget h3 {\n            font-family: {{ font_heading | default('system-ui') }};\n            margin-bottom: 1rem;\n            padding-bottom: 0.5rem;\n            border-bottom: 2px solid var(--accent-color);\n        }\n        .sidebar-widget ul {\n            list-style: none;\n        }\n        .sidebar-widget li {\n            padding: 0.5rem 0;\n            border-bottom: 1px solid var(--border-color);\n        }\n        .sidebar-widget li:last-child {\n            border-bottom: none;\n        }\n        \n        footer {\n            background: var(--nav-bg);\n            color: var(--nav-text);\n            padding: 2rem;\n            text-align: center;\n            margin-top: 4rem;\n        }\n    </style>\n</head>\n<body>\n    <header>\n        <div class=\"header-content\">\n            <a href=\"/\" class=\"logo\">{{ site_name }}</a>\n            <nav>\n                <ul>\n                    {% for link in nav_links %}\n                    <li><a href=\"{{ link.url }}\">{{ link.label }}</a></li>\n                    {% endfor %}\n                </ul>\n            </nav>\n        </div>\n    </header>\n    \n    <section class=\"page-header\">\n        <h1>{{ page_title | default('Blog') }}</h1>\n        {% if page_subtitle %}\n        <p>{{ page_subtitle }}</p>\n        {% endif %}\n    </section>\n    \n    <div class=\"container\">\n        <main>\n            {{ content | safe }}\n        </main>\n        \n        <aside class=\"sidebar\">\n            <div class=\"sidebar-widget\">\n                <h3>About</h3>\n                <p>{{ site_description | default('A blog about interesting topics.') }}</p>\n            </div>\n            <div class=\"sidebar-widget\">\n                <h3>Categories</h3>\n                <ul>\n                    <li><a href=\"#\">Technology</a></li>\n                    <li><a href=\"#\">Design</a></li>\n                    <li><a href=\"#\">Business</a></li>\n                </ul>\n            </div>\n        </aside>\n    </div>\n    \n    <footer>\n        <p>&copy; 2026 {{ site_name }}. All rights reserved.</p>\n    </footer>\n</body>\n</html>",
  "css_content": "",
  "js_content": "",
  "default_config": {
    "accent_color": "#2ea44f",
    "font_heading": "system-ui",
    "font_body": "system-ui, -apple-system, sans-serif",
    "page_title": "Blog",
    "page_subtitle": "Latest posts and updates"
  }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if title and title != site_name %}{{ title }} - {% endif %}{{ site_name }}</title>
    {% if site_description %}<meta name="description" content="{{ site_description }}">{% endif %}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --bg-color: var(--bg-color-light, #ffffff);
            --text-color: var(--text-color-light, #333333);
            --accent-color: {{ accent_color | default('#2ea44f') }};
            --nav-bg: var(--nav-bg-light, #24292f);
            --nav-text: #ffffff;
            --card-bg: var(--card-bg-light, #ffffff);
            --border-color: var(--border-color-light, #d0d7de);
            --sidebar-bg: var(--card-bg-light, #f6f8fa);
        }
        [data-theme="dark"] {
            --bg-color: #0d1117;
            --text-color: #c9d1d9;
            --nav-bg: #161b22;
            --card-bg: #161b22;
            --border-color: #30363d;
            --sidebar-bg: #161b22;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: {{ font_body | default('system-ui, -apple-system, sans-serif') }}; background: var(--bg-color); color: var(--text-color); line-height: 1.6; }
        a { color: var(--accent-color); text-decoration: none; }
        a:hover { text-decoration: underline; }
        header { background: var(--nav-bg); padding: 1rem 2rem; }
        .header-content { max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; }
        .logo { font-size: 1.5rem; font-weight: bold; color: var(--nav-text); }
        nav ul { display: flex; list-style: none; gap: 1.5rem; }
        nav a { color: var(--nav-text); font-weight: 500; }
        .page-header { background: var(--sidebar-bg); border-bottom: 1px solid var(--border-color); padding: 3rem 2rem; text-align: center; }
        .page-header h1 { font-family: {{ font_heading | default('system-ui') }}; font-size: 2.5rem; margin-bottom: 0.5rem; }
        .container { max-width: 1200px; margin: 0 auto; padding: 2rem; display: grid; grid-template-columns: 1fr 300px; gap: 2rem; }
        @media (max-width: 768px) { .container { grid-template-columns: 1fr; } }
        .posts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem; }
        .post-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; overflow: hidden; transition: transform 0.2s, box-shadow 0.2s; }
        .post-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.15); }
        .post-card img { width: 100%; height: 200px; object-fit: cover; }
        .post-content { padding: 1.5rem; }
        .post-card h3 { font-family: {{ font_heading | default('system-ui') }}; margin-bottom: 0.5rem; }
        .meta { color: var(--text-color); opacity: 0.7; font-size: 0.875rem; margin-bottom: 1rem; }
        .excerpt { color: var(--text-color); opacity: 0.8; }
        .sidebar { display: flex; flex-direction: column; gap: 2rem; }
        .sidebar-widget { background: var(--sidebar-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; }
        .sidebar-widget h3 { font-family: {{ font_heading | default('system-ui') }}; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 2px solid var(--accent-color); }
        .sidebar-widget ul { list-style: none; }
        .sidebar-widget li { padding: 0.5rem 0; border-bottom: 1px solid var(--border-color); }
        .sidebar-widget li:last-child { border-bottom: none; }
        footer { background: var(--nav-bg); color: var(--nav-text); padding: 2rem; text-align: center; margin-top: 4rem; }
    </style>
</head>
<body>
    <header>
        <div class="header-content">
            <a href="/" class="logo">{{ site_name }}</a>
            <nav><ul>{% for link in nav_links %}<li><a href="{{ link.url }}">{{ link.label }}</a></li>{% endfor %}</ul></nav>
        </div>
    </header>
    {% if posts %}
    <section class="page-header"><h1>Blog</h1><p>Latest posts and updates</p></section>
    <div class="container">
        <main>
            <div class="posts-grid">
            {% for post in posts %}
                <article class="post-card">
                    {% if post.featured_image %}<img src="{{ post.featured_image }}" alt="{{ post.title }}">{% endif %}
                    <div class="post-content">
                        <h3><a href="/blog/{{ post.slug }}.html">{{ post.title }}</a></h3>
                        <p class="meta">{{ post.published_at }}</p>
                        <p class="excerpt">{{ post.excerpt | default('') }}</p>
                    </div>
                </article>
            {% endfor %}
            </div>
        </main>
        <aside class="sidebar">
            <div class="sidebar-widget"><h3>About</h3><p>{{ site_description | default('A blog about interesting topics.') }}</p></div>
        </aside>
    </div>
    {% elif content %}
    <section class="page-header"><h1>{{ page_title | default('Blog') }}</h1>{% if page_subtitle %}<p>{{ page_subtitle }}</p>{% endif %}</section>
    <div class="container"><main>{{ content | safe }}</main><aside class="sidebar"><div class="sidebar-widget"><h3>About</h3><p>{{ site_description | default('A blog about interesting topics.') }}</p></div></aside></div>
    {% else %}
    <section class="page-header"><h1>{{ page_title | default('Blog') }}</h1>{% if page_subtitle %}<p>{{ page_subtitle }}</p>{% endif %}</section>
    <div class="container"><main></main><aside class="sidebar"><div class="sidebar-widget"><h3>About</h3><p>{{ site_description | default('A blog about interesting topics.') }}</p></div></aside></div>
    {% endif %}
    <footer><p>&copy; 2026 {{ site_name }}. All rights reserved.</p></footer>
</body>
</html>

# =============================================================================
# REQUIRED - Fill these in before starting
# =============================================================================

# Your domain (required for HTTPS)
DOMAIN=yourdomain.com

# Cloudflare API (for automatic HTTPS via Let's Encrypt)
CF_API_EMAIL=your-cloudflare-email@example.com
CF_API_KEY=your-cloudflare-api-key
ACME_EMAIL=your-email@example.com

# =============================================================================
# Database
# =============================================================================
POSTGRES_USER=blog
POSTGRES_PASSWORD=changeme
POSTGRES_DB=blog_platform
DATABASE_URL=postgres://blog:changeme@postgres:5432/blog_platform

# =============================================================================
# MinIO (S3-compatible file storage)
# =============================================================================
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=blog-media
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# =============================================================================
# App Server
# =============================================================================
APP_HOST=0.0.0.0
APP_PORT=3000
RUST_LOG=info

# =============================================================================
# Security
# =============================================================================
# IMPORTANT: Change this to a random 32+ character string in production!
SESSION_SECRET=dev-secret-change-in-production-min-32-chars!!
